<!-- heron_simulator/launch/simulation_full.launch -->
<!-- Full simulation -->
<launch>
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Arguments -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <arg name="gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="headless" default="false"/>
  
  <!-- Robot spawn position (at dock) -->
  <arg name="x" default="0.0"/>
  <arg name="y" default="0.0"/>
  <arg name="z" default="0.0"/>
  <arg name="yaw" default="0.0"/>
  
  <!-- Stack control -->
  <arg name="use_oracle" default="true"/>
  <arg name="use_mariner" default="true"/>
  <arg name="use_mock_defector" default="true"/>
  <arg name="use_cbf_filter" default="false"/>
  <arg name="use_interactive_marker" default="false"/>
  <arg name="use_ground_truth_nav" default="true"/>
  <arg name="topic_contract_guard_delay_sec" default="20.0"/>
  <arg name="use_rviz" default="false"/>
  <arg name="rviz_config" default="$(find slam_grande)/rviz/nav_debug.rviz"/>

  <!-- Static-map workflow -->
  <arg name="build_map" default="false"/>
  <arg name="map_builder" default="sensor"/>
  <arg name="run_map" default="true"/>
  <arg name="map_file" default="$(find mariner)/maps/simulation.yaml"/>
  <arg name="map_output_dir" default="$(find mariner)/maps/generated"/>
  <arg name="map_name" default="sim_runtime"/>
  <arg name="map_anchors_file" default="$(find slam_grande)/data/anchors_sim.yaml"/>

  <!-- Canonical Topic Contract -->
  <arg name="topic_pose_gt" default="/pose_gt"/>
  <arg name="topic_odom" default="/state/odometry"/>
  <arg name="topic_odom_filtered" default="/state/odometry/filtered"/>
  <arg name="topic_cmd_vel_raw" default="/cmd_vel_raw"/>
  <arg name="topic_cmd_vel" default="/cmd_vel"/>
  <arg name="topic_cmd_drive" default="/cmd_drive"/>
  <arg name="topic_thruster_left" default="/thrusters/1/input"/>
  <arg name="topic_thruster_right" default="/thrusters/0/input"/>
  <arg name="mixer_config" default="$(find heron_simulator)/config/twist_to_drive.yaml"/>
  <arg name="topic_nav_goal" default="/mariner/final_pose"/>
  <arg name="topic_nav_goal_pose" default="/mariner/goal"/>
  <arg name="topic_nav_goal_anchor" default="/mariner/goal_anchor"/>
  <arg name="topic_nav_ok" default="/mariner/status/nav_ok"/>
  <arg name="topic_nav_status" default="/mariner/status/move_base"/>
  <arg name="topic_oracle_input" default="/oracle/input"/>
  <arg name="topic_oracle_output" default="/oracle/output"/>
  <arg name="topic_oracle_status" default="/oracle/status"/>
  <arg name="topic_oracle_anchors" default="/oracle/map/anchors"/>
  <arg name="topic_imu_data" default="/sensors/imu/data"/>
  <arg name="topic_lidar_h_points" default="/sensors/lidar/hori/points"/>
  <arg name="topic_lidar_v_points" default="/sensors/lidar/vert/points"/>
  <arg name="topic_sonar_scan" default="/sensors/sonar/scan"/>
  <arg name="topic_camera_f1_image" default="/sensors/camera/f1/image_raw"/>
  <arg name="topic_camera_f2_image" default="/sensors/camera/f2/image_raw"/>
  <arg name="topic_dlio_odom" default="/state/dlio/odometry"/>
  <arg name="topic_dlio_pose" default="/state/dlio/pose"/>
  <arg name="topic_dlio_path" default="/state/dlio/path"/>
  <arg name="topic_dlio_map" default="/state/dlio/map"/>
  
  <!-- Oracle config -->
  <arg name="llm_model" default="deepseek-v3.1:671b-cloud"/>
  <arg name="anchor_file" default="$(find slam_grande)/data/anchors.yaml"/>
  
  <!-- Optional DLIO mapping -->
  <arg name="use_dlio" default="false"/>
  <arg name="use_vessel_dynamics" default="false"/>

  <!-- Gazebo ownership -->
  <arg name="start_gazebo" default="true"/>
  <arg name="gazebo_master_port" default="11345"/>
  <arg name="gazebo_verbose" default="false"/>
  <arg name="force_software_rendering" default="false"/>
  <arg name="control_startup_delay_sec" default="2.0"/>

  <!-- Ensure all included nodes use the same Gazebo master -->
  <env name="GAZEBO_MASTER_URI" value="http://127.0.0.1:$(arg gazebo_master_port)"/>
  <!-- Benchmark against ig_handle: Use custom sensor URDF extras -->
  <!-- Note: We use 'config' arg to pass a file that exports HERON_URDF_EXTRAS -->
  <!-- <env name="HERON_URDF_EXTRAS" ...> was ineffective for xacro command -->

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Use simulation time -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <param name="/use_sim_time" value="true"/>
  <rosparam command="load" file="$(find slam_grande)/config/topic_contract.yaml" ns="/topic_contract"/>
  <param name="/topic_contract/topics/pose_gt" value="$(arg topic_pose_gt)"/>
  <param name="/topic_contract/topics/odom" value="$(arg topic_odom)"/>
  <param name="/topic_contract/topics/odom_filtered" value="$(arg topic_odom_filtered)"/>
  <param name="/topic_contract/topics/cmd_vel_raw" value="$(arg topic_cmd_vel_raw)"/>
  <param name="/topic_contract/topics/cmd_vel" value="$(arg topic_cmd_vel)"/>
  <param name="/topic_contract/topics/cmd_drive" value="$(arg topic_cmd_drive)"/>
  <param name="/topic_contract/topics/thruster_left" value="$(arg topic_thruster_left)"/>
  <param name="/topic_contract/topics/thruster_right" value="$(arg topic_thruster_right)"/>
  <param name="/topic_contract/topics/nav_goal" value="$(arg topic_nav_goal)"/>
  <param name="/topic_contract/topics/nav_goal_pose" value="$(arg topic_nav_goal_pose)"/>
  <param name="/topic_contract/topics/nav_goal_anchor" value="$(arg topic_nav_goal_anchor)"/>
  <param name="/topic_contract/topics/nav_ok" value="$(arg topic_nav_ok)"/>
  <param name="/topic_contract/topics/nav_status" value="$(arg topic_nav_status)"/>
  <param name="/topic_contract/topics/oracle_input" value="$(arg topic_oracle_input)"/>
  <param name="/topic_contract/topics/oracle_output" value="$(arg topic_oracle_output)"/>
  <param name="/topic_contract/topics/oracle_status" value="$(arg topic_oracle_status)"/>
  <param name="/topic_contract/topics/oracle_anchors" value="$(arg topic_oracle_anchors)"/>
  <param name="/topic_contract/topics/imu_data" value="$(arg topic_imu_data)"/>
  <param name="/topic_contract/topics/lidar_h_points" value="$(arg topic_lidar_h_points)"/>
  <param name="/topic_contract/topics/lidar_v_points" value="$(arg topic_lidar_v_points)"/>
  <param name="/topic_contract/topics/sonar_scan" value="$(arg topic_sonar_scan)"/>
  <param name="/topic_contract/topics/camera_f1_image" value="$(arg topic_camera_f1_image)"/>
  <param name="/topic_contract/topics/camera_f2_image" value="$(arg topic_camera_f2_image)"/>
  <param name="/topic_contract/topics/dlio_odom" value="$(arg topic_dlio_odom)"/>
  <param name="/topic_contract/topics/dlio_pose" value="$(arg topic_dlio_pose)"/>
  <param name="/topic_contract/topics/dlio_path" value="$(arg topic_dlio_path)"/>
  <param name="/topic_contract/topics/dlio_map" value="$(arg topic_dlio_map)"/>
  <param name="/topic_contract/modules/simulation_truth/enabled" value="true"/>
  <param name="/topic_contract/modules/state/enabled" value="true"/>
  <param name="/topic_contract/modules/mariner/enabled" value="$(arg use_mariner)"/>
  <param name="/topic_contract/modules/goal_routing/enabled" value="$(eval 'true' if str(arg('use_mariner')).lower() == 'true' and str(arg('use_oracle')).lower() == 'true' else 'false')"/>
  <param name="/topic_contract/modules/oracle/enabled" value="$(arg use_oracle)"/>
  <param name="/topic_contract/modules/ig_handle_sensors/enabled" value="true"/>
  <param name="/topic_contract/modules/dlio/enabled" value="$(arg use_dlio)"/>

  <!-- Fail fast if a stale Gazebo or web stack is already running. -->
  <node pkg="heron_simulator" type="sim_preflight.py" name="simulation_preflight"
        output="screen" required="true">
    <param name="gazebo_master_port" value="$(arg gazebo_master_port)"/>
    <param name="allow_existing_gazebo" value="$(eval str(arg('start_gazebo')).lower() != 'true')"/>
    <rosparam param="required_free_ports">[8070, 8080, 8081, 9095]</rosparam>
  </node>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Launch Heron in Gazebo using internal heron_simulator -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  
  <!-- Anchor Configuration: Auto-select simulation anchors -->
  <node pkg="slam_grande" type="select_anchors.sh" name="anchor_updater" args="sim" output="screen" unless="$(arg use_oracle)" />

  <node if="$(eval str(arg('build_map')).lower() == 'true' and str(arg('map_builder')).lower() == 'anchors')"
        pkg="mariner"
        type="generate_map_from_anchors.py"
        name="build_static_nav_map"
        output="screen"
        args="--anchors $(arg map_anchors_file) --output $(arg map_output_dir) --name $(arg map_name)"/>

  <node if="$(eval str(arg('build_map')).lower() == 'true' and str(arg('map_builder')).lower() != 'anchors')"
        pkg="mariner"
        type="generate_map_from_pointcloud.py"
        name="build_sensor_nav_map"
        output="screen">
    <param name="map_topic" value="$(arg topic_dlio_map)"/>
    <param name="output_dir" value="$(arg map_output_dir)"/>
    <param name="map_name" value="$(arg map_name)"/>
  </node>

  <include file="$(find heron_simulator)/launch/heron_world.launch">
    <arg name="start_gazebo" value="$(arg start_gazebo)"/>
    <arg name="gazebo_master_port" value="$(arg gazebo_master_port)"/>
    <arg name="config" value="ig_handle_benchmark"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="verbose" value="$(arg gazebo_verbose)"/>
    <arg name="force_software_rendering" value="$(arg force_software_rendering)"/>
    <arg name="x" value="$(arg x)"/>
    <arg name="y" value="$(arg y)"/>
    <arg name="yaw" value="$(arg yaw)"/>
    <arg name="enable_ekf" value="$(eval 'false' if str(arg('use_ground_truth_nav')).lower() == 'true' else 'true')"/>
    <arg name="enable_navsat" value="$(eval 'false' if str(arg('use_ground_truth_nav')).lower() == 'true' else 'true')"/>
    <arg name="use_interactive_marker" value="$(arg use_interactive_marker)"/>
    <arg name="control_startup_delay_sec" value="$(arg control_startup_delay_sec)"/>
    <arg name="cmd_vel_to_mixer" value="$(arg topic_cmd_vel)"/>
    <arg name="drive_topic" value="$(arg topic_cmd_drive)"/>
    <arg name="left_thruster_topic" value="$(arg topic_thruster_left)"/>
    <arg name="right_thruster_topic" value="$(arg topic_thruster_right)"/>
    <arg name="mixer_config" value="$(arg mixer_config)"/>
  </include>

  <!-- Keep a stable project-wide odometry contract.
       In simulation, default to Gazebo ground truth for navigation stability.
       When disabled, fall back to the filtered localization stack. -->
  <group if="$(arg use_ground_truth_nav)">
    <node pkg="mariner" type="dlio_odom_to_tf.py" name="sim_pose_gt_to_tf" output="screen">
      <param name="odom_topic" value="$(arg topic_pose_gt)"/>
      <param name="parent_frame" value="odom"/>
      <param name="child_frame" value="base_footprint"/>
      <param name="respect_msg_frames" value="false"/>
    </node>

    <node pkg="topic_tools" type="relay" name="state_odom_relay"
          args="$(arg topic_pose_gt) $(arg topic_odom)" output="screen"/>
    <node pkg="topic_tools" type="relay" name="state_odom_filtered_relay"
          args="$(arg topic_pose_gt) $(arg topic_odom_filtered)" output="screen"/>
  </group>

  <group unless="$(arg use_ground_truth_nav)">
    <node pkg="topic_tools" type="relay" name="state_odom_relay"
          args="/odometry/filtered $(arg topic_odom)" output="screen"/>
    <node pkg="topic_tools" type="relay" name="state_odom_filtered_relay"
          args="/odometry/filtered $(arg topic_odom_filtered)" output="screen"/>
  </group>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Spawn inspection targets (pillars, dock, pipe inlet) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node pkg="heron_simulator" type="spawn_inspection_models.py" 
        name="spawn_inspection_models" output="screen" required="true"
        launch-prefix="bash -c 'sleep 5; $0 $@'">
    <param name="hold_open" value="true"/>
  </node>

  <!-- Static TF: map -> odom -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom"
        args="0 0 0 0 0 0 map odom"/>

  <!-- Sensor TFs are handled by URDF and robot_state_publisher -->

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Navigation Stack (move_base) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(arg use_mariner)">
    <include file="$(find mariner)/launch/move_base.launch">
      <arg name="base_frame" value="base_link"/>
      <arg name="odom_frame" value="odom"/>
      <arg name="cmd_vel_out" value="$(arg topic_cmd_vel_raw)"/>
      <arg name="cmd_vel_safe" value="$(arg topic_cmd_vel)"/>
      <arg name="odom_topic" value="$(arg topic_odom)"/>
      <arg name="use_cbf_filter" value="$(arg use_cbf_filter)"/>
      <arg name="use_map_server" value="$(arg run_map)"/>
      <arg name="map_file" value="$(arg map_file)"/>
      <arg name="local_costmap_overlay_config" value="$(find mariner)/config/local_costmap_sim.yaml"/>
      <arg name="teb_local_planner_overlay_config" value="$(find mariner)/config/teb_local_planner_sim.yaml"/>
      <!-- <arg name="use_map_server" value="false"/> -->
    </include>

    <node pkg="mariner" type="goal_status_relay.py" name="move_base_status_relay" output="screen">
      <param name="input_topic" value="/move_base/status"/>
      <param name="output_topic" value="$(arg topic_nav_status)"/>
    </node>

    <!-- Move base goal manager: consume PoseStamped goals from ORACLE -->
    <node pkg="mariner" type="move_base_goal_manager.py" name="move_base_goal_manager" output="screen">
      <param name="goal_topic" value="$(arg topic_nav_goal)"/>
      <param name="action_name" value="/move_base"/>
      <param name="nav_ok_topic" value="$(arg topic_nav_ok)"/>
      <param name="frame_id" value="map"/>
    </node>
  </group>

  <!-- Standardize command semantics:
       /cmd_vel_raw = planner output
       /cmd_vel     = vehicle-facing command
       If safety filtering is disabled, /cmd_vel mirrors /cmd_vel_raw. -->
  <node unless="$(arg use_cbf_filter)"
        pkg="topic_tools"
        type="relay"
        name="cmd_vel_passthrough"
        args="$(arg topic_cmd_vel_raw) $(arg topic_cmd_vel)"
        output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Mock Defector Service -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node if="$(arg use_mock_defector)" 
        pkg="heron_simulator" type="mock_defector_service.py" 
        name="mock_defector" output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- ORACLE Stack -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(arg use_oracle)">
    <include file="$(find oracle)/launch/oracle.launch">
      <arg name="anchor_pose_map_file" value="$(arg anchor_file)"/>
      <arg name="llm_model" value="$(arg llm_model)"/>
      <arg name="odom_topic" value="$(arg topic_odom)"/>
      <arg name="viz_topic" value="/sensors/camera/f1/image_raw"/>
      <arg name="topic_input" value="$(arg topic_oracle_input)"/>
      <arg name="topic_output" value="$(arg topic_oracle_output)"/>
      <arg name="topic_status" value="$(arg topic_oracle_status)"/>
      <arg name="topic_anchors" value="$(arg topic_oracle_anchors)"/>
      <arg name="topic_nav_goal_anchor" value="$(arg topic_nav_goal_anchor)"/>
      <arg name="topic_nav_goal_pose" value="$(arg topic_nav_goal_pose)"/>
      <arg name="topic_nav_ok" value="$(arg topic_nav_ok)"/>
      <arg name="nav_goal_topic" value="$(arg topic_nav_goal)"/>
      <arg name="sensor_profile" value="simulation"/>
      <arg name="inspect_service" value="/defector/capture_and_analyze"/>
    </include>
  </group>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- DLIO LiDAR-Inertial SLAM -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(eval str(arg('use_dlio')).lower() == 'true' or str(arg('build_map')).lower() == 'true')">
    <include file="$(find heron_simulator)/launch/dlio.launch">
      <arg name="robot_namespace" value="robot"/>
      <arg name="pointcloud_topic" value="$(arg topic_lidar_h_points)"/>
      <arg name="imu_topic" value="$(arg topic_imu_data)"/>
      <arg name="odom_topic" value="$(arg topic_dlio_odom)"/>
      <arg name="pose_topic" value="$(arg topic_dlio_pose)"/>
      <arg name="map_topic" value="$(arg topic_dlio_map)"/>
      <arg name="path_topic" value="$(arg topic_dlio_path)"/>
      <arg name="rviz" value="false"/>
    </include>
  </group>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Fix for broken navsat_vel_cov node (Python 2 vs 3 issue) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node pkg="heron_simulator" type="vel_cov_fixed.py" name="navsat_vel_cov_fixed" output="screen"/>

  <node pkg="mariner" type="costmap_to_image.py" name="costmap_visualizer" output="screen"/>

  <node pkg="heron_simulator" type="topic_contract_guard.py" name="topic_contract_guard"
        output="screen" required="true"
        launch-prefix="bash -c 'sleep $(arg topic_contract_guard_delay_sec); $0 $@'">
    <param name="contract_ns" value="/topic_contract"/>
  </node>

  <include file="$(find slam_grande)/launch/include/rviz_nav.launch">
    <arg name="use_rviz" value="$(arg use_rviz)"/>
    <arg name="rviz_config" value="$(arg rviz_config)"/>
  </include>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Optional external hydrodynamics model.
       Disabled by default because the base Gazebo Heron dynamics are sufficient
       for nominal navigation runs, and this extra 6DOF wrench model can
       destabilize the boat when layered on top. -->
  <node if="$(arg use_vessel_dynamics)" pkg="heron_simulator" type="vessel_dynamics.py"
        name="vessel_dynamics" output="screen">
    <param name="namespace" value=""/>
    <param name="odom_topic" value="/pose_gt"/>
    <rosparam param="water_current_mean">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="water_current_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wind_mean">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wind_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wave_force_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wave_torque_std">[0.0, 0.0, 0.0]</rosparam>
  </node>
  
</launch>
