<!-- heron_simulator/launch/simulation_full.launch -->
<!-- Full simulation -->
<launch>
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Arguments -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <arg name="gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="headless" default="false"/>
  
  <!-- Robot spawn position (at dock) -->
  <arg name="x" default="0.0"/>
  <arg name="y" default="0.0"/>
  <arg name="z" default="0.0"/>
  <arg name="yaw" default="0.0"/>
  
  <!-- Stack control -->
  <arg name="use_oracle" default="true"/>
  <arg name="use_mariner" default="true"/>
  <arg name="use_mock_defector" default="true"/>
  <arg name="use_cbf_filter" default="false"/>
  <arg name="use_interactive_marker" default="false"/>
  
  <!-- Oracle config -->
  <arg name="llm_model" default="deepseek-v3.1:671b-cloud"/>
  <arg name="anchor_file" default="$(find slam_grande)/data/anchors.yaml"/>
  
  <!-- Optional DLIO mapping -->
  <arg name="use_dlio" default="false"/>
  <arg name="use_vessel_dynamics" default="false"/>

  <!-- Gazebo ownership -->
  <arg name="start_gazebo" default="true"/>
  <arg name="gazebo_master_port" default="11345"/>
  <arg name="gazebo_verbose" default="false"/>
  <arg name="force_software_rendering" default="false"/>
  <arg name="control_startup_delay_sec" default="2.0"/>

  <!-- Ensure all included nodes use the same Gazebo master -->
  <env name="GAZEBO_MASTER_URI" value="http://127.0.0.1:$(arg gazebo_master_port)"/>
  <!-- Benchmark against ig_handle: Use custom sensor URDF extras -->
  <!-- Note: We use 'config' arg to pass a file that exports HERON_URDF_EXTRAS -->
  <!-- <env name="HERON_URDF_EXTRAS" ...> was ineffective for xacro command -->

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Use simulation time -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <param name="/use_sim_time" value="true"/>

  <!-- Fail fast if a stale Gazebo or web stack is already running. -->
  <node pkg="heron_simulator" type="sim_preflight.py" name="simulation_preflight"
        output="screen" required="true">
    <param name="gazebo_master_port" value="$(arg gazebo_master_port)"/>
    <param name="allow_existing_gazebo" value="$(eval str(arg('start_gazebo')).lower() != 'true')"/>
    <rosparam param="required_free_ports">[8070, 8080, 8081, 9095]</rosparam>
  </node>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Launch Heron in Gazebo using internal heron_simulator -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  
  <!-- Anchor Configuration: Auto-select simulation anchors -->
  <node pkg="slam_grande" type="select_anchors.sh" name="anchor_updater" args="sim" output="screen" unless="$(arg use_oracle)" />

  <include file="$(find heron_simulator)/launch/heron_world.launch">
    <arg name="start_gazebo" value="$(arg start_gazebo)"/>
    <arg name="gazebo_master_port" value="$(arg gazebo_master_port)"/>
    <arg name="config" value="ig_handle_benchmark"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="verbose" value="$(arg gazebo_verbose)"/>
    <arg name="force_software_rendering" value="$(arg force_software_rendering)"/>
    <arg name="x" value="$(arg x)"/>
    <arg name="y" value="$(arg y)"/>
    <arg name="yaw" value="$(arg yaw)"/>
    <arg name="enable_ekf" value="true"/>
    <arg name="enable_navsat" value="true"/>
    <arg name="use_interactive_marker" value="$(arg use_interactive_marker)"/>
    <arg name="control_startup_delay_sec" value="$(arg control_startup_delay_sec)"/>
  </include>

  <!-- Keep a stable project-wide odometry topic independent of optional DLIO. -->
  <node pkg="topic_tools" type="relay" name="state_odom_relay"
        args="/odometry/filtered /state/odometry" output="screen"/>
  <node pkg="topic_tools" type="relay" name="state_odom_filtered_relay"
        args="/odometry/filtered /state/odometry/filtered" output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Spawn inspection targets (pillars, dock, pipe inlet) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node pkg="heron_simulator" type="spawn_inspection_models.py" 
        name="spawn_inspection_models" output="screen" required="true"
        launch-prefix="bash -c 'sleep 5; $0 $@'">
    <param name="hold_open" value="true"/>
  </node>

  <!-- Static TF: map -> odom -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom"
        args="0 0 0 0 0 0 map odom"/>

  <!-- Sensor TFs are handled by URDF and robot_state_publisher -->

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Navigation Stack (move_base) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(arg use_mariner)">
    <include file="$(find mariner)/launch/move_base.launch">
      <arg name="base_frame" value="base_link"/>
      <arg name="odom_frame" value="odom"/>
      <arg name="cmd_vel_out" value="/cmd_vel_raw"/>
      <arg name="use_cbf_filter" value="$(arg use_cbf_filter)"/>
      <!-- <arg name="use_map_server" value="false"/> -->
    </include>

    <!-- Move base goal manager: consume PoseStamped goals from ORACLE -->
    <node pkg="mariner" type="move_base_goal_manager.py" name="move_base_goal_manager" output="screen">
      <param name="goal_topic" value="/mariner/final_pose"/>
      <param name="action_name" value="/move_base"/>
      <param name="nav_ok_topic" value="mariner/nav_ok"/>
      <param name="frame_id" value="map"/>
    </node>
  </group>

  <param name="/move_base/TebLocalPlannerROS/odom_topic" value="/state/odometry"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Mock Defector Service -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node if="$(arg use_mock_defector)" 
        pkg="heron_simulator" type="mock_defector_service.py" 
        name="mock_defector" output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- ORACLE Stack -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(arg use_oracle)">
    <include file="$(find oracle)/launch/oracle.launch">
      <arg name="anchor_pose_map_file" value="$(arg anchor_file)"/>
      <arg name="llm_model" value="$(arg llm_model)"/>
      <arg name="odom_topic" value="/state/odometry"/>
      <arg name="viz_topic" value="/sensors/camera/f1/image_raw"/>
      <arg name="nav_goal_topic" value="/mariner/final_pose"/>
      <arg name="inspect_service" value="/defector/capture_and_analyze"/>
    </include>
  </group>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- DLIO LiDAR-Inertial SLAM -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <group if="$(arg use_dlio)">
    <include file="$(find heron_simulator)/launch/dlio.launch">
      <arg name="robot_namespace" value="robot"/>
      <arg name="pointcloud_topic" value="/sensors/lidar/hori/points"/>
      <arg name="imu_topic" value="/sensors/imu/data"/>
      <arg name="odom_topic" value="/state/dlio/odometry"/>
      <arg name="pose_topic" value="/state/dlio/pose"/>
      <arg name="map_topic" value="/state/dlio/map"/>
      <arg name="path_topic" value="/state/dlio/path"/>
      <arg name="rviz" value="false"/>
    </include>
  </group>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Fix for broken navsat_vel_cov node (Python 2 vs 3 issue) -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <node pkg="heron_simulator" type="vel_cov_fixed.py" name="navsat_vel_cov_fixed" output="screen"/>

  <node pkg="mariner" type="costmap_to_image.py" name="costmap_visualizer" output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- Optional external hydrodynamics model.
       Disabled by default because the base Gazebo Heron dynamics are sufficient
       for nominal navigation runs, and this extra 6DOF wrench model can
       destabilize the boat when layered on top. -->
  <node if="$(arg use_vessel_dynamics)" pkg="heron_simulator" type="vessel_dynamics.py"
        name="vessel_dynamics" output="screen">
    <param name="namespace" value=""/>
    <param name="odom_topic" value="/pose_gt"/>
    <rosparam param="water_current_mean">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="water_current_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wind_mean">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wind_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wave_force_std">[0.0, 0.0, 0.0]</rosparam>
    <rosparam param="wave_torque_std">[0.0, 0.0, 0.0]</rosparam>
  </node>
  
</launch>
