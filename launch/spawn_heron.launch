<launch>

  <!-- Debug flag -->
  <arg name="hydro_debug" default="0"/>
  <rosparam param="/use_sim_time">true</rosparam>

  <!-- Vehicle's initial pose -->
  <arg name="x"     default="0"/>
  <arg name="y"     default="0"/>
  <arg name="z"     default="0.0"/>
  <arg name="roll"  value="0"/>
  <arg name="pitch" value="0"/>
  <arg name="yaw"   default="0"/>

  <arg name="namespace" default=""/>
  <arg name="config" default="base" />
  <arg name="use_interactive_marker" default="false" />
  <arg name="control_startup_delay_sec" default="0.0" />
  <arg name="cmd_vel_to_mixer" default="/cmd_vel" />
  <arg name="drive_topic" default="/cmd_drive" />
  <arg name="left_thruster_topic" default="/thrusters/1/input" />
  <arg name="right_thruster_topic" default="/thrusters/0/input" />
  <arg name="mixer_config" default="$(find heron_simulator)/config/twist_to_drive.yaml" />

  <group ns="/$(arg namespace)">

    <!-- Load the upstream Heron model in simulation mode so /cmd_vel drives
         the same cmd_drive -> thruster -> hull path as the real stack. -->
    <group if="$(eval arg('namespace') == '')">
      <param name="robot_description"
             command="$(find heron_description)/scripts/env_run $(find heron_description)/urdf/configs/$(arg config)
                      $(find xacro)/xacro '$(find heron_description)/urdf/heron.urdf.xacro'
                      debug:=$(arg hydro_debug) simulation:=true" />
    </group>

    <group unless="$(eval arg('namespace') == '')">
      <param name="robot_description"
             command="$(find heron_description)/scripts/env_run $(find heron_description)/urdf/configs/$(arg config)
                      $(find xacro)/xacro '$(find heron_description)/urdf/heron.urdf.xacro'
                      debug:=$(arg hydro_debug) simulation:=true
                      namespace:=$(arg namespace) suffix_ns:=$(arg namespace)/" />
    </group>

    <!-- Publish robot state (TF) -->
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen" />

    <!-- Publish default thruster joint states so RViz always gets the full
         robot model TF tree, even when Gazebo's joint-state plugin is absent
         or late to connect. -->
    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher" output="screen">
      <param name="use_gui" value="false" />
      <param name="rate" value="15" />
    </node>

    <!-- Spawn the model in Gazebo -->
    <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen" required="true"
          args="-urdf -x $(arg x) -y $(arg y) -z $(arg z) -R $(arg roll) -P $(arg pitch) -Y $(arg yaw) 
                -model $(arg namespace)heron -param robot_description -b"/>

    <!-- Launch Teleop (optional, for joystick) -->
    <include file="$(find heron_control)/launch/teleop.launch">
      <arg name="joystick"  value="false" />
      <arg name="namespace" value="$(arg namespace)" />
      <arg name="use_interactive_marker" value="$(arg use_interactive_marker)" />
    </include>

    <!-- Keep /cmd_vel as the vehicle-facing command interface. -->
    <node pkg="mariner" type="twist_to_drive.py" name="twist_to_drive" output="screen">
      <remap from="cmd_vel" to="$(arg cmd_vel_to_mixer)" />
      <remap from="cmd_drive" to="$(arg drive_topic)" />
      <rosparam command="load" file="$(arg mixer_config)" />
    </node>

    <node pkg="heron_simulator" type="cmd_drive_translate.py" name="cmd_drive_to_thrusters" output="screen">
      <param name="namespace" value="$(arg namespace)" />
      <param name="drive_topic" value="$(arg drive_topic)" />
      <param name="left_thruster_topic" value="$(arg left_thruster_topic)" />
      <param name="right_thruster_topic" value="$(arg right_thruster_topic)" />
      <rosparam command="load" file="$(find heron_simulator)/config/thruster_dynamics.yaml" />
    </node>

    <!-- Translate navsat/velocity for compatibility (optional) -->
    <node pkg="heron_simulator" type="navsat_vel_translate.py" name="navvel_translate" />

  </group>

  <!-- Localization Stack (EKF/NavSat) -->
  <arg name="enable_ekf" default="true"/>
  <arg name="enable_navsat" default="true"/>
  
  <group ns="/$(arg namespace)">
    <rosparam param="ekf_localization_node/tf_prefix" subst_value="True">$(arg namespace)</rosparam>
    <rosparam param="navsat_transform_node/tf_prefix" subst_value="True">$(arg namespace)</rosparam>
    <rosparam param="navsat_transform_node/use_odometry_yaw">true</rosparam>
      
    <include file="$(find heron_control)/launch/control.launch">
      <arg name="enable_ekf" value="$(arg enable_ekf)"/>
      <arg name="enable_navsat" value="$(arg enable_navsat)"/>
      <arg name="startup_delay_sec" value="$(arg control_startup_delay_sec)"/>
    </include>
  </group>

</launch>
