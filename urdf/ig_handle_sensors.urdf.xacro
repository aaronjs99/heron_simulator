<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ====================================================================== -->
  <!-- IG Handle Sensors Configuration                                        -->
  <!-- User coordinate frame: x-forward, y-right, z-down                      -->
  <!-- ROS coordinate frame: x-forward, y-left, z-up                          -->
  <!-- Conversion: negate Y and Z                                             -->
  <!-- ====================================================================== -->

  <!-- Material Definitions -->
  <material name="sensor_black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>
  <material name="sensor_blue">
    <color rgba="0.2 0.4 0.8 1"/>
  </material>
  <material name="sensor_yellow">
    <color rgba="0.9 0.8 0.1 1"/>
  </material>

  <!-- ====================================================================== -->
  <!-- Lidar H (Horizontal) -->
  <!-- Sensor origins come from slam_grande/config/sensors/heron_sensor_suite.yaml
       via HERON_* environment variables exported by ig_handle_benchmark. -->
  <!-- Horizontal VLP-16: +X starboard, +Y bow, +Z up. -->
  <!-- Velodyne VLP-16 model: 16 channels, 360 degree sweep, 10 Hz at 600 RPM. -->
  <!-- ====================================================================== -->
  <!-- Mount pole for Lidar H -->
  <link name="lidar_h_mount">
    <visual>
      <geometry><cylinder radius="0.03" length="0.22"/></geometry>
      <material name="sensor_black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="lidar_h_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_h_mount"/>
    <origin xyz="$(optenv HERON_LIDAR_H_MOUNT_XYZ)" rpy="0 0 0"/>
  </joint>

  <link name="lidar_h_link">
    <visual>
      <geometry><cylinder radius="0.05086" length="0.07238"/></geometry>
      <material name="sensor_black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="lidar_h_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_h_link"/>
    <origin xyz="$(optenv HERON_LIDAR_H_XYZ)" rpy="$(optenv HERON_LIDAR_H_RPY)"/>
  </joint>

  <gazebo reference="lidar_h_link">
    <sensor type="ray" name="lidar_h_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle> <!-- -15 deg -->
            <max_angle>0.261799</max_angle>  <!-- +15 deg -->
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>200.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar_h_controller" filename="libgazebo_ros_velodyne_laser.so">
        <topicName>/sensors/lidar/hori/points</topicName>
        <frameName>lidar_h_link</frameName>
        <min_range>0.1</min_range>
        <max_range>200.0</max_range>
        <gaussianNoise>0.005</gaussianNoise>
        <organize_cloud>false</organize_cloud>
        <min_intensity>0.0</min_intensity>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ====================================================================== -->
  <!-- Lidar V (Vertical) -->
  <!-- Vertical VLP-16: +X starboard, +Y up, +Z aft. Runtime TF ownership is
       lidar_h_link -> lidar_v_link; the mount visual remains in base_link. -->
  <!-- ====================================================================== -->
  <!-- Mount pole for Lidar V -->
  <link name="lidar_v_mount">
    <visual>
      <geometry><cylinder radius="0.025" length="0.14"/></geometry>
      <material name="sensor_black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="lidar_v_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_v_mount"/>
    <origin xyz="$(optenv HERON_LIDAR_V_MOUNT_XYZ)" rpy="0 0 0"/>
  </joint>

  <link name="lidar_v_link">
    <visual>
      <geometry><cylinder radius="0.05" length="0.07"/></geometry>
      <material name="sensor_black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="lidar_v_joint" type="fixed">
    <parent link="lidar_h_link"/>
    <child link="lidar_v_link"/>
    <origin xyz="$(optenv HERON_LIDAR_V_XYZ)" rpy="$(optenv HERON_LIDAR_V_RPY)"/>
  </joint>

  <gazebo reference="lidar_v_link">
    <sensor type="ray" name="lidar_v_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle> <!-- -15 deg -->
            <max_angle>0.261799</max_angle>  <!-- +15 deg -->
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>200.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar_v_controller" filename="libgazebo_ros_velodyne_laser.so">
        <topicName>/sensors/lidar/vert/points</topicName>
        <frameName>lidar_v_link</frameName>
        <min_range>0.1</min_range>
        <max_range>200.0</max_range>
        <gaussianNoise>0.005</gaussianNoise>
        <organize_cloud>false</organize_cloud>
        <min_intensity>0.0</min_intensity>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ====================================================================== -->
  <!-- Sonar -->
  <!-- Imagenex DT100 profile model. User: (0, 0, 80)mm -> ROS: (0, 0, -0.08)m. -->
  <!-- The acoustic +X axis is pitched down into ROS -Z. The ray fan models the -->
  <!-- 480-beam, 120 degree cross-track profile. The physical 3 degree along-track -->
  <!-- beam width is a footprint property, not extra profile beams, so Gazebo emits -->
  <!-- one profile slice per ping. -->
  <!-- ====================================================================== -->
  <link name="sonar_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.05"/></geometry>
      <material name="sensor_blue"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="sonar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_link"/>
    <origin xyz="0 0 -0.08" rpy="0 1.5708 0"/>
  </joint>

  <gazebo reference="sonar_link">
    <sensor type="ray" name="sonar">
      <update_rate>20</update_rate>
      <ray>
         <scan>
            <horizontal>
               <samples>480</samples>
               <resolution>1</resolution>
               <min_angle>-1.047198</min_angle>
               <max_angle>1.047198</max_angle>
            </horizontal>
            <vertical>
               <samples>1</samples>
               <resolution>1</resolution>
               <min_angle>0.0</min_angle>
               <max_angle>0.0</max_angle>
            </vertical>
         </scan>
         <range>
            <min>0.5</min>
            <max>100.0</max>
            <resolution>0.02</resolution>
         </range>
      </ray>
      <plugin name="sonar_plugin" filename="libgazebo_ros_velodyne_laser.so">
        <topicName>/sensors/sonar/scan</topicName>
        <frameName>sonar_link</frameName>
        <min_range>0.5</min_range>
        <max_range>100.0</max_range>
        <gaussianNoise>0.003</gaussianNoise>
        <organize_cloud>false</organize_cloud>
        <min_intensity>0.0</min_intensity>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ====================================================================== -->
  <!-- Camera Mount Pole -->
  <!-- ====================================================================== -->
  <link name="camera_mount">
    <visual>
      <geometry><cylinder radius="0.03" length="0.20"/></geometry>
      <material name="sensor_black"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount"/>
    <origin xyz="$(optenv HERON_CAMERA_MOUNT_XYZ)" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="ig_handle_forge_camera"
               params="id xyz rpy topic_suffix camera_name distortion_k1 distortion_k2 distortion_k3">
    <link name="${id}">
      <visual>
        <geometry><box size="0.06 0.06 0.04"/></geometry>
        <material name="sensor_blue"/>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${id}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${id}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <link name="${id}_optical"/>
    <joint name="${id}_optical_joint" type="fixed">
      <parent link="${id}"/>
      <child link="${id}_optical"/>
      <origin xyz="0 0 0" rpy="-1.5707963267948966 0 -1.5707963267948966"/>
    </joint>

    <gazebo reference="${id}">
      <sensor type="camera" name="camera_${id}_sensor">
        <update_rate>15.0</update_rate>
        <camera name="${camera_name}">
          <horizontal_fov>1.60</horizontal_fov>
          <image>
            <width>1280</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>100</far>
          </clip>
          <visibility_mask>4294967294</visibility_mask>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <plugin name="camera_${id}_controller" filename="libgazebo_ros_camera.so">
          <alwaysOn>true</alwaysOn>
          <updateRate>15.0</updateRate>
          <cameraName>sensors/camera/${topic_suffix}</cameraName>
          <imageTopicName>image_raw</imageTopicName>
          <cameraInfoTopicName>camera_info</cameraInfoTopicName>
          <frameName>${id}_optical</frameName>
          <hackBaseline>0.07</hackBaseline>
          <distortionK1>${distortion_k1}</distortionK1>
          <distortionK2>${distortion_k2}</distortionK2>
          <distortionK3>${distortion_k3}</distortionK3>
          <distortionT1>0.0</distortionT1>
          <distortionT2>0.0</distortionT2>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!-- ====================================================================== -->
  <!-- Forge camera stack -->
  <!-- F1/F2 face forward; F3/F4 face upward. F1/F4 are right/starboard mounts
       when looking from behind, and F2/F3 are left/port mounts. These frame
       names intentionally match the real Forge driver frame IDs and shared
       sensor YAML. -->
  <!-- ====================================================================== -->
  <xacro:if value="$(optenv HERON_CAMERA_F1 1)">
    <xacro:ig_handle_forge_camera id="F1"
                                  xyz="$(optenv HERON_CAMERA_F1_XYZ)"
                                  rpy="$(optenv HERON_CAMERA_F1_RPY)"
                                  topic_suffix="f1"
                                  camera_name="forward_starboard"
                                  distortion_k1="-0.0100"
                                  distortion_k2="0.0030"
                                  distortion_k3="-0.0020"/>
  </xacro:if>
  <xacro:if value="$(optenv HERON_CAMERA_F2 1)">
    <xacro:ig_handle_forge_camera id="F2"
                                  xyz="$(optenv HERON_CAMERA_F2_XYZ)"
                                  rpy="$(optenv HERON_CAMERA_F2_RPY)"
                                  topic_suffix="f2"
                                  camera_name="forward_port"
                                  distortion_k1="-0.0090"
                                  distortion_k2="0.0028"
                                  distortion_k3="-0.0019"/>
  </xacro:if>
  <xacro:if value="$(optenv HERON_CAMERA_F3 0)">
    <xacro:ig_handle_forge_camera id="F3"
                                  xyz="$(optenv HERON_CAMERA_F3_XYZ)"
                                  rpy="$(optenv HERON_CAMERA_F3_RPY)"
                                  topic_suffix="f3"
                                  camera_name="upward_port"
                                  distortion_k1="-0.0100"
                                  distortion_k2="0.0030"
                                  distortion_k3="-0.0020"/>
  </xacro:if>
  <xacro:if value="$(optenv HERON_CAMERA_F4 1)">
    <xacro:ig_handle_forge_camera id="F4"
                                  xyz="$(optenv HERON_CAMERA_F4_XYZ)"
                                  rpy="$(optenv HERON_CAMERA_F4_RPY)"
                                  topic_suffix="f4"
                                  camera_name="upward_starboard"
                                  distortion_k1="-0.0090"
                                  distortion_k2="0.0028"
                                  distortion_k3="-0.0019"/>
  </xacro:if>

  <!-- ====================================================================== -->
  <!-- IMU Visual (for debugging) -->
  <!-- IMU pose comes from the canonical sensor suite through HERON_IMU_*.
       Encased MTi-30 AHRS device ID 0368xxxx: connector side is -X and exits
       aft, the unit is upside down, so +X is forward, +Y is starboard/right,
       and +Z points down toward the water. -->
  <!-- Note: imu_link is already defined in base Heron URDF, just add visual -->
  <!-- ====================================================================== -->
  <!-- Debug link marker - placed at approximate IMU location -->
  <link name="debug_extra_link">
    <visual>
      <geometry><box size="0.05 0.03 0.02"/></geometry>
      <material name="sensor_yellow"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="debug_extra_joint" type="fixed">
    <parent link="base_link"/>
    <child link="debug_extra_link"/>
    <origin xyz="$(optenv HERON_IMU_XYZ)" rpy="$(optenv HERON_IMU_RPY)"/>
  </joint>

  <gazebo>
    <plugin name="imu_controller_ighandle" filename="libhector_gazebo_ros_imu.so">
      <updateRate>50.0</updateRate>
      <bodyName>imu_link</bodyName>
      <frameId>imu_link</frameId>
      <topicName>/sensors/imu/data</topicName>
      <accelDrift>0.005 0.005 0.005</accelDrift>
      <accelGaussianNoise>0.005 0.005 0.005</accelGaussianNoise>
      <rateDrift>0.005 0.005 0.005 </rateDrift>
      <rateGaussianNoise>0.005 0.005 0.005 </rateGaussianNoise>
      <headingDrift>0.005</headingDrift>
      <headingGaussianNoise>0.005</headingGaussianNoise>
    </plugin>
  </gazebo>

</robot>
